# Open Deep Research — 环境变量模板
#
# 用法: cp .env.example .env, 然后填真值。
# .env 已在 .gitignore,不提交。
#
# 模块 → 变量:
#   PostgreSQL (evidence/*, api/server.py):    POSTGRES_*
#   Search (search_providers.py):              TAVILY_API_KEY, SEARXNG_URL
#   LLM (llm.py):                              MINIMAX_*, OPENAI_API_KEY, ANTHROPIC_API_KEY
#   Langfuse tracing (可选):                   LANGFUSE_*
#   LangSmith tracing (可选):                  LANGSMITH_*
#   Supabase auth/storage (可选):              SUPABASE_URL, SUPABASE_KEY
#   HTTP server (api/server.py):               HOST, PORT
#
# 安全性: API keys / tokens 不要 commit。.env 已经 ignored;
# 如果要 systemd 跑,把同样的值放 /etc/open_deep_research/open_deep_research.env。

# =============================================================================
# PostgreSQL — 所有 evidence 数据落这里
# =============================================================================
# Docker 起容器时: docker inspect odr-postgres 看真密码
POSTGRES_HOST=172.17.0.2
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=odr_v2

# =============================================================================
# Search providers — full mode 必须有
# =============================================================================
# mode='full' 强制要求;mode='evidence-only' 不读这个 var
TAVILY_API_KEY=

# SearXNG 自部署的 base URL (可选;不设走 Tavily 单一来源)
# 当 TAVILY_API_KEY 配额耗尽时,SearXNG fallback 接管
SEARXNG_URL=http://127.0.0.1:8080

# =============================================================================
# LLM providers
# =============================================================================
# 主用 — MiniMax-M3 (Anthropic-protocol endpoint)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_GROUP_ID=

# 备用 — OpenAI / Anthropic 直连 / Google
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# =============================================================================
# Observability (optional — 不设也不报错)
# =============================================================================
# LangSmith (LangChain tracing)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=open-deep-research-dev

# Langfuse (Phase 6 stub 已接,真接需要这些)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3000

# =============================================================================
# Supabase (可选 — 用其 auth + vector 时才设)
# =============================================================================
SUPABASE_URL=
SUPABASE_KEY=

# =============================================================================
# 内部开关 — 控制是否从 .env 读 key 还是从配置 dict 读
# =============================================================================
GET_API_KEYS_FROM_CONFIG=true

# =============================================================================
# HTTP server (api/server.py)
# =============================================================================
# 默认 0.0.0.0:2024;Dockerfile.api 已经 EXPOSE 2024
HOST=0.0.0.0
PORT=2024

# =============================================================================
# 测试集成开关 (集成测试默认 skip,设 1 才真连 PG)
# =============================================================================
# INTEGRATION_TESTS=1
