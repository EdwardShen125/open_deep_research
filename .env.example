# Open Deep Research — 环境变量模板
#
# 用法: cp .env.example .env, 然后填真值。
# .env 已在 .gitignore,不提交。
#
# 哪些模块用哪些 var:
#   PostgreSQL (evidence/*, api/server.py):    POSTGRES_*
#   Search (search_providers.py):              TAVILY_API_KEY, SEARXNG_URL
#   Observability (llm.py):                    LANGFUSE_*
#   HTTP server (api/server.py):               HOST, PORT

# =============================================================================
# PostgreSQL — 真调研阶段 1 起就开始用,所有 evidence 数据落这里
# =============================================================================
# Docker 起容器时: docker inspect odr-postgres 看真密码
POSTGRES_HOST=172.17.0.2
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=odr_v2_pg_pass_change_me
POSTGRES_DB=odr_v2

# =============================================================================
# Search providers — full mode 必须有
# =============================================================================
# mode='full' 强制要求;mode='evidence-only' 不读这个 var
TAVILY_API_KEY=tvly-dev-REPLACE_ME

# SearXNG 自部署的 base URL(可选;不设走 Tavily 单一来源)
# 当 TAVILY_API_KEY 配额耗尽时,SearXNG fallback 接管
# Docker 起 SearXNG 后从 host 访问:
#   1) SearXNG 容器在 docker bridge network 上,host 上 127.0.0.1:8080 默认连不上
#      (IPv6-only bind issue)。用 docker inspect odr-searxng 查 .NetworkSettings.IPAddress
#   2) 当前 odr-v2-infra 网络下 SearXNG 在 172.19.0.3:8080(host 上能用)
SEARXNG_URL=http://172.19.0.3:8080

# =============================================================================
# Observability — Langfuse tracing (Phase 6 stub 接好,真接需要这些)
# =============================================================================
# 不设也不报错,只关闭 tracing
# LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
# LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME
# LANGFUSE_HOST=http://localhost:3000

# =============================================================================
# HTTP server (api/server.py)
# =============================================================================
# 默认 0.0.0.0:8000;可改成 127.0.0.1:8765 等
HOST=0.0.0.0
PORT=8000

# =============================================================================
# 测试集成开关(集成测试默认 skip,设 1 才真连 PG)
# =============================================================================
# INTEGRATION_TESTS=1