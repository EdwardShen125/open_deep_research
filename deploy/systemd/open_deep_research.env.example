# Open Deep Research systemd unit env file.
# 拷到 /etc/open_deep_research/open_deep_research.env,权限 0600,owner root:odr.
#
# 所有值跟顶层 .env 一致。systemd 不会加载顶层 .env,
# 所以这一份是 host 直接跑 uvicorn (不用 docker) 的唯一渠道。
#
# 安全:绝密值不要 commit;本文件模式 0600 + owner root:odr。

# --- PostgreSQL ---
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=odr_v2

# --- Search providers ---
TAVILY_API_KEY=
SEARXNG_URL=http://127.0.0.1:8080

# --- LLM provider ---
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_GROUP_ID=

# --- Optional (commented if not used) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=false
# LANGSMITH_PROJECT=open-deep-research
# SUPABASE_URL=
# SUPABASE_KEY=
