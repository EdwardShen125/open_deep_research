# syntax=docker/dockerfile:1.4
FROM python:3.13-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/app/.venv \
    UV_NO_DEV=1

# tini = PID 1 signal handling, libxml2/libxslt1 = lxml wheels
RUN apt-get update && apt-get install --no-install-recommends -y \
        tini ca-certificates curl libxml2 libxslt1.1 \
    && rm -rf /var/lib/apt/lists/*

# uv (fast package manager, matches repo lockfile uv.lock)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

WORKDIR /app

# Layer 1: deps only — cache-friendly, no source yet.
COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-install-project --no-extra ml

# Layer 2: copy source + project install (setuptools build, no dev, no ml).
COPY src ./src
COPY langgraph.json pyproject.toml uv.lock README.md LICENSE ./
COPY deploy/docker-entrypoint.sh /usr/local/bin/entrypoint.sh

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-extra ml

RUN chmod +x /usr/local/bin/entrypoint.sh

ENV PORT=2024 HOST=0.0.0.0 PYTHONPATH=/app/src
EXPOSE 2024 8088

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -fsS "http://127.0.0.1:${PORT}/healthz" || exit 1

ENTRYPOINT ["/usr/bin/tini","--","/usr/local/bin/entrypoint.sh"]
CMD ["api"]
